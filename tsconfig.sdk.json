{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "standalone-scripts/marco-sdk/dist",
    "declaration": false,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@sdk/*": ["standalone-scripts/marco-sdk/src/*"]
    }
  },
  "include": [
    "standalone-scripts/marco-sdk/src/**/*.ts",
    "standalone-scripts/types/**/*.ts",
    "standalone-scripts/types/**/*.d.ts"
  ],
  "exclude": ["node_modules"]
}
